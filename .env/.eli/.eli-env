#[ "$2" == "u" ] && printf ${_und}$1m; [ "$2" == "bu" ] && printf ${_bld}$1m${und};
#[ "$2" == "bl" ] && printf ${_blink}$1m; [ "$2" == "bbl" ] && printf ${_bld}$1m${blink};
