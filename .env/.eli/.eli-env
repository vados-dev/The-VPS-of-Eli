#    bublk=$(_c 30 bu); bured=$(_c 31 bu); bugrn=$(_c 32 bu); buyel=$(_c 33 bu); bublu=$(_c 34 bu); bumag=$(_c 35 bu); bucy=$(_c 36 bu); buwh=$(_c 37 bu);
