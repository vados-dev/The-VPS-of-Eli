#    bstblk=$(_c 30 bst); bstred=$(_c 31 bst); bstgrn=$(_c 32 bst); bstyel=$(_c 33 bst); bstblu=$(_c 34 bst); bstmag=$(_c 35 bst); bstcy=$(_c 36 bst); bstwh=$(_c 37 bst);
    rev=$(tput rev);
    sym_ok=$(printf "${grn}%s${nc}" ✅); sym_err=$(printf "${red}%s${nc}" ❌); install=$(printf "${bnc}%s${nc}" 💿);
    sym_info=$(printf "${bblu}%s${nc}" 📋);sym_warn=$(printf "${byel}%s${nc}" "⚠⚠"); sym_dbg=$(printf "${bwh}%s${nc}" 🔧); sym_star=$(printf "${byel}%s${nc}" ✨);
else
    neg=''; blink=''; rev='';
    blk=''; red=''; grn=''; yel=''; blu=''; mag=''; cy=''; wh='';
    bblk=''; bred=''; bgrn=''; byel=''; bblu=''; bmag=''; bcy=''; bwh='';
    sym_ok='✅'; sym_err='❌'; install='💿'; sym_info='📋'; sym_warn='⚠⚠'; sym_dbg='🔧'; sym_star='✨';
fi

toend=$(tput hpa $(tput cols))$(tput cub 6);
_resh=$(printf '\x23');

app_title() {
    local name=${pr_name:-$dir_name};
    printf " ${bnc}[${nc}${bmag}${name}${bnc}]${nc}";
}
printstr() {
    local _head=$(app_title);
    if [[ "$#" == 4 ]]; then
       printf "$_head %s $2${bnc}$1${byel} $3\n${nc}" "$4";
    elif [[ "$#" == 3 ]]; then
       printf "$_head %s ${bnc}$1${byel} $2\n${nc}" "$3";
    elif [[ "$#" == 2 ]]; then
       printf "$_head %s ${bnc}$1\n${nc}" "$2";
    else
       printf "$_head ${bnc}$1\n${nc}";
    fi
}

stars=${byel}'✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨✨'${nc};
line='##############################################################';
dashes='───────────────────────────────────────────────────────────────────────────────'
equals='═══════════════════════════════════════════════════════════════════════════════'
spaces='                                                                               '

###########################
### Функции логирования ###
###########################
save_log() {
    local log="${DEFAULT_LOG}";
    local _error;
    if ${SAVE_LOG}; then
        if ! mkdir -p "$(dirname "${log}")" || ! echo $* >> "${log}" >/dev/null 2>&1; then
            printstr "Ошибка записи лога '${log}'. ${bred}ERROR:${nc} " "$?" "$sym_err";
            exit 1;
        fi
    fi
}
log_msg() {
    local type="$1";local msg="$2";
    local ts=$(date '+%b %d %T');
    local entry="[$ts] $type: $msg";
    case "$type" in
        INFO)  printstr "${bblue}$type: ${bnc}$msg" "$sym_info" ;;
        OK)    printstr "${bgrn}$type: ${bnc}$msg" "$sym_ok" ;;
        WARN)  printstr "${byel}$type: ${bnc}$msg" "$sym_warn" ;;
        ERROR) printstr "${bred}$type: ${bnc}$msg" "$sym_err" >&2 ;;
        DEBUG) printstr "${bwh}$type: ${bnc}$msg" "$sym_dbg" >&2 ;;
        *) app_title "Error" "$sym_err" ;;
    esac
    save_log "$entry";
}

log()       { log_msg "Инфо" "$1"; }
log_ok()    { log_msg "Ok" "$1"; }
log_warn()  { log_msg "Зацени" "$1"; }
log_error() { log_msg "Ошибка" "$1"; }
log_debug() { log_msg "Отладка" "$1"; }
die()       { log_error "Сдохла: $1"; log_error "Работа прервана. Лог: $DEFAULT_LOG"; exit 1; }

#log "scrp by ERITEK & Loo1"; #log_warn "scrp by ERITEK & Loo1"; log_error "scrp by ERITEK & Loo1"; log_debug "scrp by ERITEK & Loo1";die; exit 0;
#print_ok()      { printstr "$1 %s\n" "$sym_ok"; }; print_warn()    { printstr "$1 %s\n" "$sym_warn"; }; print_err()     { printstr "${bred}$1${nc} %s\n" "$sym_err"; }; print_info()    { printstr "$1 %s\n" "$sym_star"; };

print_info()    { log "$1"; }
print_ok()      { log_ok "$1"; }
print_warn()    { log_warn "$1"; }
print_err()     { log_error "$1"; }
print_section() {
    printf "\n  ${bmag} ${resh}${bnc}$1${nc}\n"
    printf "   ${bmag}${dashes}${nc}\n";
}
